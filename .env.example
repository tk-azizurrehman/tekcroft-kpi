# =============================================================================
# TekCroft KPI CRM — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env or .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL via Prisma)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME?sslmode=require"

# -----------------------------------------------------------------------------
# NextAuth.js
# -----------------------------------------------------------------------------
# The canonical URL of your deployed app (no trailing slash)
NEXTAUTH_URL="https://your-domain.com"

# A strong random secret — generate one with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_TO_A_STRONG_RANDOM_SECRET"

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
# Restrict login to a specific email domain (include the @ symbol)
# Prefixed with NEXT_PUBLIC_ so client-side validation can use it too
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAIN="@tekcroft.com"

# Display name used in the UI header and metadata
APP_NAME="TekCroft KPI CRM"

# How many years of KPI data to retain
DATA_RETENTION_YEARS=5

# -----------------------------------------------------------------------------
# CORS (optional — only needed if a separate frontend calls the API)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins, e.g. https://app.example.com
# Leave empty to allow only same-origin requests (the default).
CORS_ALLOWED_ORIGINS=""

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# Port for `next start` (defaults to 3000)
PORT=3000

# Node environment — set to "production" on your live server
NODE_ENV="production"
